{
  "manifest_version": 3,
  "name": "HTML Snapshot Viewer",
  "version": "1.0.0",
  "description": "Capture the current DOM HTML of the active tab and view/copy/save it in a separate window.",
  "action": {
    "default_title": "HTML Snapshot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "unlimitedStorage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  }
}